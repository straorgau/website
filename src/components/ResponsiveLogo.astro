---
interface Props {
  height?: number;
  width?: number;
}

const { height, width } = Astro.props; 
---

<>
  <img 
    src="/vectors/stra_light.svg"
    height={height}
    width={width}
    alt="Student Transport Riders Association logo"
    class="dark:hidden"
  >
  
  <img 
    src="/vectors/stra_dark.svg"
    height={height}
    width={width}
    alt="Student Transport Riders Association logo"
    class="hidden dark:inline"
  >
</>